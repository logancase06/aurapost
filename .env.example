# ─────────────────────────────────────────────────────────────────────────────
# AuraPost — Variables d'environnement
# Copier en .env.local et remplir. Ne jamais committer .env.local.
# TOUTES les intégrations ont un mock propre : l'app tourne sans aucune clé.
# Générer les secrets : openssl rand -base64 32  (ou openssl rand -hex 32)
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────────────────────
# Générer : openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Base de données (Turso) ───────────────────────────────────────────────────
# HTTPS obligatoire (pas libsql://).
# Absent → fallback SQLite EN MÉMOIRE auto-créé (données non persistées).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Génération de contenu IA ──────────────────────────────────────────────────
# Priorité : ANTHROPIC_API_KEY (api) > CLAUDE_TUNNEL_URL (tunnel) > mock enrichi.
# Mode actif loggé au démarrage : "[AuraPost] Génération mode: ..."

# Chemin 1 — Production : API Anthropic directe
ANTHROPIC_API_KEY=          # console.anthropic.com
ANTHROPIC_MODEL=            # optionnel, défaut: claude-sonnet-4-6

# Chemin 2 — Tunnel Cloudflare vers Claude Code local (dev / beta)
CLAUDE_TUNNEL_URL=          # ex: https://aurapost.trycloudflare.com
TUNNEL_SECRET=              # openssl rand -base64 32 — partagé Netlify ↔ machine locale

# Chemin 3 — Mock enrichi automatique si aucune variable ci-dessus
# Forcer le mock (CI / dev) :
AURAPOST_USE_MOCK=

# OBLIGATOIRE en prod — sans cette variable, la génération est synchrone
# et dépasse le timeout Netlify (26s) dans ~50% des cas. Le verrou
# generatingAt peut rester bloqué 5-10 min (libéré ensuite par le cron
# reconcile-stuck-jobs, mais l'utilisateur voit une erreur immédiate).
GENERATION_ASYNC=true

# ── Édition d'images par IA (GPT Image 1.5) ──────────────────────────────────
# Absent → édition image désactivée (mock propre — aucun crash côté serveur).
# Obtenir : platform.openai.com → API keys
OPENAI_API_KEY=           # sk-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Absent → billing en mode démonstration (checkout désactivé, historique mocké).
# Voir docs/stripe-activation.md pour la procédure complète d'activation.
STRIPE_SECRET_KEY=                    # sk_live_... (Stripe Dashboard → Clés API)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # pk_live_... (Stripe Dashboard → Clés API)
STRIPE_WEBHOOK_SECRET=                # whsec_... (Stripe CLI ou Dashboard → Webhooks)
STRIPE_PRICE_CONTENT_ONLY=            # price_... plan Coach (39€/mois)
STRIPE_PRICE_PACK_COMPLET=            # price_... plan Coach+Site (79€/mois)

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Absent → emails simulés en console (mock).
RESEND_API_KEY=
RESEND_FROM=AuraPost <onboarding@aurapost.fr>

# ── Storage (Cloudflare R2 / S3 compatible) ───────────────────────────────────
# Absent → upload désactivé (erreur propre).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=                        # OBLIGATOIRE en prod — domaine public des photos R2/CDN
                                      # (ex: https://media.aurapost.fr). Absent → photos des
                                      # sites vitrines bloquées par la CSP img-src.

# ── Cache & Rate limiting (Upstash Redis) ─────────────────────────────────────
# OBLIGATOIRE en prod — absent → fallback in-memory par instance Lambda :
# le rate limiting n'est pas partagé entre instances, un attaquant peut
# contourner en parallélisant les requêtes. Loggé en WARN au démarrage si absent.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Admin & Crons ─────────────────────────────────────────────────────────────
# Emails autorisés à accéder à /admin (séparés par des virgules), en plus du rôle 'admin'.
ADMIN_EMAILS=
# Secret des routes /api/cron/* — Générer : openssl rand -hex 32
CRON_SECRET=
# Secret HMAC des liens de désabonnement email (RGPD/LCEN) — Générer : openssl rand -hex 32
# Absent → throw en dev, liens mailto de repli en prod.
UNSUBSCRIBE_SECRET=

# ── Alerting ──────────────────────────────────────────────────────────────────
# Email destinataire des alertes admin (jobs échoués, reconcile stuck jobs).
# Absent → logError uniquement (pas d'email).
ADMIN_ALERT_EMAIL=

# ── Calendrier (abonnements iCal) ─────────────────────────────────────────────
# Secret HMAC pour les URLs d'abonnement calendrier stables (sans session cookie).
# Absent → utilise NEXTAUTH_SECRET avec préfixe "cal:" (acceptable mais isolé < idéal).
# Générer : openssl rand -base64 32
CALENDAR_SECRET=

# ── Observabilité (logs de production) ────────────────────────────────────────
# Drain Axiom : lib/logger.ts l'active automatiquement si ces deux vars sont presentes.
# Absent → console.log/error uniquement (Netlify capture les stdout des Lambda).
# Voir docs/infra/logging.md pour la procedure complete (dataset, API token).
AXIOM_DATASET=              # ex: aurapost-prod  (app.axiom.co → Datasets → New dataset)
AXIOM_TOKEN=                # ex: xaat-...       (app.axiom.co → Settings → API tokens)

# ── Divers ────────────────────────────────────────────────────────────────────
APP_DOMAIN=aurapost.fr
MAINTENANCE_MODE=
