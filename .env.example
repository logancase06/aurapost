# ─────────────────────────────────────────────────────────────────────────────
# AuraPost — Variables d'environnement
# Copier en .env.local et remplir. Ne jamais committer .env.local.
# TOUTES les intégrations ont un mock propre : l'app tourne sans aucune clé.
# ─────────────────────────────────────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Générer : openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Turso (HTTPS obligatoire, pas libsql://) ─────────────────────────────────
# Absent → fallback SQLite EN MÉMOIRE auto-créé (données non persistées).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Génération de contenu (SDK Claude Code) ──────────────────────────────────
# Le SDK @anthropic-ai/claude-code (query()) s'appuie sur l'auth locale de Claude Code —
# AUCUNE ANTHROPIC_API_KEY requise. Indisponible → fallback générateur mock déterministe.
# Forcer le mock (CI / dev) :
AURAPOST_USE_MOCK=

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Absent → emails simulés en console (mock).
RESEND_API_KEY=
RESEND_FROM=AuraPost <onboarding@aurapost.fr>

# ── Stripe ───────────────────────────────────────────────────────────────────
# Absent → billing en mode démonstration (historique mocké, checkout désactivé).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CONTENT_ONLY=
STRIPE_PRICE_PACK_COMPLET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Upstash Redis (optionnel — fallback rate limit/cache in-memory) ──────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Admin & cron ─────────────────────────────────────────────────────────────
# Emails autorisés à accéder à /admin (séparés par des virgules), en plus du rôle 'admin'.
ADMIN_EMAILS=
# Secret des routes /api/cron/* (relance onboarding). Générer : openssl rand -hex 32
CRON_SECRET=

# ── Divers ───────────────────────────────────────────────────────────────────
APP_DOMAIN=aurapost.fr
MAINTENANCE_MODE=
